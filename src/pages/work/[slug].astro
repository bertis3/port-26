---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ChapterLayout from '../../layouts/ChapterLayout.astro';
import CreativeLayout from '../../layouts/CreativeLayout.astro';
import SectionHead from '../../components/mdx/SectionHead';
import SectionTitle from '../../components/mdx/SectionTitle';
import Pullquote from '../../components/mdx/Pullquote';
import SystemDiagram from '../../components/chapters/SystemDiagram';
import { sectionId, sectionLabel } from '../../utils/chapter';
import { workItems } from '../../data/content';

export async function getStaticPaths() {
  const [chapterEntries, creativeEntries] = await Promise.all([
    getCollection('chapters'),
    getCollection('creatives'),
  ]);
  return [
    ...chapterEntries.map(entry => ({
      params: { slug: entry.id },
      props: { collection: 'chapters' as const, entry },
    })),
    ...creativeEntries.map(entry => ({
      params: { slug: entry.id },
      props: { collection: 'creatives' as const, entry },
    })),
  ];
}

type Props =
  | { collection: 'chapters'; entry: CollectionEntry<'chapters'> }
  | { collection: 'creatives'; entry: CollectionEntry<'creatives'> };

const props = Astro.props;

// render() works identically for both collection types
const { Content, headings } = await render(props.entry as CollectionEntry<'chapters'>);

// Compute prev/next from the canonical workItems order with wrap-around
type ComputedNavRef = { slug: string; title: string; type: 'project' | 'creative'; num: string; meta: string };

const idx = workItems.findIndex(w => w.slug === props.entry.id);
const total = workItems.length;

function toNavRef(item: typeof workItems[number]): ComputedNavRef {
  return {
    slug: item.slug,
    title: item.title,
    type: item.type === 'case' ? 'project' : 'creative',
    num: item.n,
    meta: item.meta,
  };
}

const computedPrev = idx >= 0 ? toNavRef(workItems[(idx - 1 + total) % total]) : undefined;
const computedNext = idx >= 0 ? toNavRef(workItems[(idx + 1) % total]) : undefined;

// Prepare layout props in the frontmatter where TS control-flow narrowing works
let isCreative = false;

let creativeData: {
  number: string;
  title: string;
  category: string;
  client: string;
  year: number;
  methods: string[];
  singleImage: boolean;
  creatives: CollectionEntry<'creatives'>['data']['creatives'];
  prev?: ComputedNavRef;
  next?: ComputedNavRef;
} | undefined;

let chapterData: {
  number: string;
  title: string;
  category: string;
  era: string;
  methods: string[];
  outcomes: CollectionEntry<'chapters'>['data']['outcomes'];
  prev?: ComputedNavRef;
  next?: ComputedNavRef;
  artifacts: CollectionEntry<'chapters'>['data']['artifacts'];
  sections: { text: string; label: string; id: string }[];
  totalItems: number;
} | undefined;

if (props.collection === 'creatives') {
  isCreative = true;
  const d = props.entry.data;
  creativeData = {
    number: d.number,
    title: d.title,
    category: d.category,
    client: d.client,
    year: d.year,
    methods: [...d.methods],
    singleImage: d.singleImage,
    creatives: [...d.creatives],
    prev: computedPrev,
    next: computedNext,
  };
} else {
  const d = props.entry.data;
  const sections = headings
    .filter(h => h.depth === 2)
    .map(h => ({ text: h.text, label: sectionLabel(h.text), id: sectionId(h.text) }));
  chapterData = {
    number: d.number,
    title: d.title,
    category: d.category,
    era: d.era,
    methods: [...d.methods],
    outcomes: [...d.outcomes],
    prev: computedPrev,
    next: computedNext,
    artifacts: [...d.artifacts],
    sections,
    totalItems: total,
  };
}
---

{isCreative && creativeData ? (
  <CreativeLayout {...creativeData}>
    <Content />
  </CreativeLayout>
) : chapterData ? (
  <ChapterLayout {...chapterData}>
    <Content
      components={{
        h2: SectionHead,
        h3: SectionTitle,
        Pullquote,
        SystemDiagram,
      }}
    />
  </ChapterLayout>
) : null}
