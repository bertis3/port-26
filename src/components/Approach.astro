---
import Label from './Label.astro';
import { processChain } from '../data/content';
---

<section class="section-border py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6 md:px-8 flex flex-col sm:flex-row gap-10">

    <div class="sm:w-[120px] sm:flex-shrink-0">
      <Label>Approach</Label>
    </div>

    <div class="flex-1">
      <p class="text-[21px] font-semibold text-ink leading-[1.25] mb-5">
        Every project has a hypothesis.<br />
        Every hypothesis has a test.<br />
        Every test has a lesson.
      </p>
      <div class="flex items-center flex-wrap">
        {processChain.map((step, i) => (
          <span class="inline-flex items-center">
            <span
              class="font-mono text-[0.8125rem] text-ink-mid px-3 py-[5px] bg-white/55 rounded-[2px]"
              style="border: 1px solid rgba(0,0,0,0.09);"
            >
              {step}
            </span>
            {i < processChain.length - 1 && (
              <span class="font-mono text-[0.8125rem] text-ink-light px-[3px]">&#8594;</span>
            )}
          </span>
        ))}
      </div>
    </div>

  </div>
</section>
