---
import { navLinks } from '../data/content';

interface Props {
  stickyLight?: boolean;
}

const { stickyLight = false } = Astro.props;

const navHrefs: Record<string, string> = {
  Work: '/#work',
  Experience: '/#experience',
};
---

<header id="site-nav">

  <!-- Desktop (≥md): home icon | GENE DAVIS · Santa Monica, CA | nav links -->
  <div class="hidden md:grid grid-cols-[1fr_auto_1fr] items-center px-10 py-[18px]">
    <a href="/" aria-label="Home" class="nav-icon">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
        <path d="M7.5 1.5L1 6.5V13.5H5.5V9.5H9.5V13.5H14V6.5L7.5 1.5Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      </svg>
    </a>
    <div class="nav-identity">
      <span class="name">GENE DAVIS</span>
      <span class="dot" aria-hidden="true">·</span>
      <span class="loc">Santa Monica, CA</span>
    </div>
    <nav class="flex gap-6 justify-end">
      {navLinks.map(link => (
        <a href={navHrefs[link] ?? '#'} class="nav-link">{link}</a>
      ))}
    </nav>
  </div>

  <!-- Mobile (<md): home icon | GENE DAVIS | hamburger -->
  <div class="md:hidden grid grid-cols-[auto_1fr_auto] items-center gap-4 px-6 py-[14px]">
    <a href="/" aria-label="Home" class="nav-icon">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
        <path d="M7.5 1.5L1 6.5V13.5H5.5V9.5H9.5V13.5H14V6.5L7.5 1.5Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
      </svg>
    </a>
    <span class="nav-name-mobile">GENE DAVIS</span>
    <button id="hamburger-btn" aria-label="Open menu" aria-expanded="false" class="nav-icon nav-hamburger">
      <svg id="icon-open" width="18" height="13" viewBox="0 0 18 13" fill="none" aria-hidden="true">
        <path d="M0 0.5H18M0 6.5H18M0 12.5H18" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="hidden">
        <path d="M2 2L14 14M14 2L2 14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="mobile-menu hidden" aria-hidden="true">
    <nav class="flex flex-col gap-5 px-6 py-5">
      {navLinks.map(link => (
        <a href={navHrefs[link] ?? '#'} class="nav-link">{link}</a>
      ))}
    </nav>
  </div>

  {stickyLight && (
    <div id="nav-progress" class="nav-progress" style="width: 0%"></div>
  )}

</header>

<!-- Spacer to offset fixed nav -->
<div class="nav-spacer" aria-hidden="true"></div>

<style>
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(246, 244, 240, 0.88);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid rgba(200, 196, 188, 0.5);
    transition: transform 280ms ease;
  }

  #site-nav.nav-hidden {
    transform: translateY(-100%);
  }

  .nav-icon {
    display: inline-flex;
    color: var(--color-ink-mid);
    transition: color 150ms ease;
    line-height: 0;
  }
  .nav-icon:hover { color: var(--color-accent); }

  .nav-hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-identity {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    font-family: var(--font-mono);
  }
  .nav-identity .name {
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
  }
  .nav-identity .dot {
    font-size: 0.625rem;
    color: var(--color-ink-light);
  }
  .nav-identity .loc {
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    color: var(--color-ink-light);
  }

  .nav-name-mobile {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    text-align: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-mid);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .nav-link:hover { color: var(--color-ink); }

  .mobile-menu {
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .nav-progress {
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.1s linear;
  }

  /* Heights match nav padding + icon + border at each breakpoint */
  .nav-spacer { height: 52px; }
  @media (max-width: 767px) {
    .nav-spacer { height: 44px; }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // ── Scroll-up reveal ──
  let lastY = window.scrollY;

  function setNavVisible(visible: boolean) {
    nav?.classList.toggle('nav-hidden', !visible);
    if (!visible) closeMobileMenu();
  }

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y < 80) {
      setNavVisible(true);
    } else if (y > lastY) {
      setNavVisible(false);
    } else {
      setNavVisible(true);
    }
    lastY = y;
  }, { passive: true });

  // ── Hamburger ──
  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    hamburgerBtn?.setAttribute('aria-expanded', 'false');
  }

  hamburgerBtn?.addEventListener('click', () => {
    const opening = mobileMenu?.classList.contains('hidden');
    if (opening) {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      hamburgerBtn?.setAttribute('aria-expanded', 'true');
    } else {
      closeMobileMenu();
    }
  });

  // Close when a mobile menu link is clicked
  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMobileMenu);
  });

  // Close on outside click
  document.addEventListener('click', (e: MouseEvent) => {
    if (nav && !nav.contains(e.target as Node)) {
      closeMobileMenu();
    }
  });
</script>
