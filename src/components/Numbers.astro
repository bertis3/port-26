---
import { stats } from '../data/content';
---

<section class="section-border py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <div class="flex gap-12 flex-wrap">
      {stats.map(stat => (
        <div>
          <div class="text-[32px] font-bold text-ink tracking-[-0.02em] leading-none">{stat.value}</div>
          <div class="font-mono text-[0.8125rem] text-ink-light mt-1.5">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
