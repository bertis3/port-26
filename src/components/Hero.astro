---
import HeroAnimation from './HeroAnimation';
---

<section class="section-border overflow-hidden">

  <div class="mx-auto max-w-6xl flex">

  <!-- Text content -->
  <div class="flex-1 py-16 md:py-24 pl-6 md:pl-8 pr-6 sm:pr-12">

    <!-- Legal name -->
    <p class="font-mono text-[0.625rem] text-ink-light tracking-[0.1em] mb-3">
      Bertis &#8220;Gene&#8221; Davis
    </p>

    <!-- GENE solid / DAVIS outlined -->
    <div class="mb-5">
      <div
        class="font-head font-bold uppercase leading-[0.88] tracking-[-0.02em] text-ink"
        style="font-size: clamp(64px, 12vw, 100px);"
      >
        Gene
      </div>
      <div
        class="font-head font-bold uppercase leading-[0.88] tracking-[-0.02em]"
        style="font-size: clamp(64px, 12vw, 100px); color: transparent; -webkit-text-stroke: 2px #18170f;"
      >
        Davis
      </div>
    </div>

    <!-- Descriptor -->
    <div class="flex items-center gap-2.5 mb-4">
      <div class="w-[22px] h-[1.5px] bg-accent flex-shrink-0"></div>
      <span class="font-mono text-[0.75rem] text-ink-mid tracking-[0.1em]">
        EXPERIMENTATION & CONVERSION LEAD · UX
      </span>
    </div>

    <!-- Bio -->
    <p class="text-sm text-ink-mid leading-[1.7] max-w-[420px] mb-5">
      Senior experimentation and conversion optimization leader with 20+ years
      bridging UX, data, and engineering. Designing disciplined programs
      that turn hypotheses into measurable growth.
    </p>

    <!-- CTAs -->
    <div class="flex gap-3 flex-wrap">
      <a
        href="#work"
        class="bg-accent text-white px-5 py-[9px] font-mono text-[0.625rem] tracking-[0.08em] rounded-full hover:opacity-90 transition-opacity"
      >
        VIEW WORK →
      </a>
      <a
        href="/Bertis-Gene-Davis_Resume_ATS.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink-mid px-5 py-2 font-mono text-[0.625rem] tracking-[0.08em] rounded-full transition-colors hover:bg-black/5"
        style="border: 1px solid rgba(0,0,0,0.09);"
      >
        RESUME ↓
      </a>
    </div>

  </div>

  <!-- Desktop photo: animation wrapper owns both the effect and the image -->
  <div class="hidden sm:flex flex-col justify-end flex-shrink-0">
    <div style="position: relative; width: 481px; height: 629px; overflow: hidden; flex-shrink: 0;">
      <HeroAnimation client:only="react" />
    </div>
  </div>

  </div>

</section>
